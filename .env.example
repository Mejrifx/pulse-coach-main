# Copy to `.env` for local dev. For production, set the same names in your host’s
# environment UI — then trigger a new build (Vite embeds VITE_* at build time).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional — never prefix with VITE_ (do not expose to the browser bundle)
# SUPABASE_SERVICE_ROLE_KEY=server_only
